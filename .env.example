PORT=3005
DASHBOARD_PORT=3006
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_AUTH_EMAIL=admin@example.com
DASHBOARD_AUTH_PASSWORD=ChangeMeStrong123!
DASHBOARD_SESSION_SECRET=replace-with-64-character-hex
NODE_ENV=production
COLLECTOR_API_KEY=change-me-please

# Local or remote Supabase API URL.
SUPABASE_URL=http://127.0.0.1:8000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

QDRANT_ENABLED=false
# Local or remote Qdrant REST URL.
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=redu_os_events
QDRANT_FALLBACK_EMBEDDINGS=true

AI_ENABLED=true
DEBUG_AI_RAW=false
# Local or remote Ollama URL. Inside podman-compose this is overridden to http://ollama:11434.
OLLAMA_URL=http://127.0.0.1:11435
OLLAMA_PORT=11435
OLLAMA_MODEL=deepseek-r1:1.5b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Activepieces or any webhook-compatible automation receiver.
# For the local mock receiver:
# AUTOMATION_WEBHOOK_URL=http://host.containers.internal:3010/webhook/reduos
# AUTOMATION_WEBHOOK_API_KEY=local-demo-key
AUTOMATION_WEBHOOK_URL=
AUTOMATION_WEBHOOK_URLS=
AUTOMATION_WEBHOOK_API_KEY=

# Activepieces module. Generated automatically by npm run modular:activepieces:up if empty.
ACTIVEPIECES_PORT=8080
AP_FRONTEND_URL=http://127.0.0.1:8080
AP_ENCRYPTION_KEY=replace-with-32-character-hex
AP_JWT_SECRET=replace-with-64-character-hex
AP_POSTGRES_DATABASE=activepieces
AP_POSTGRES_USERNAME=activepieces
AP_POSTGRES_PASSWORD=replace-with-64-character-hex
AP_EXECUTION_MODE=UNSANDBOXED
AP_CONTAINER_TYPE=WORKER_AND_APP
AP_TELEMETRY_ENABLED=false
AP_PIECES_SYNC_MODE=OFFICIAL_AUTO
AP_OWNER_EMAIL=admin@example.com
AP_OWNER_FIRST_NAME=Local
AP_OWNER_LAST_NAME=Admin
AP_OWNER_PASSWORD=ChangeMeStrong123
ACTIVEPIECES_FLOW_NAME=reduOS-Event-Automation
ACTIVEPIECES_FLOW_NAME_PREFIX=reduOS
ACTIVEPIECES_EVENT_API_KEY=replace-with-48-character-hex
ACTIVEPIECES_DISCORD_WEBHOOK_URL=

# Uptime Kuma module. Generated automatically by npm run modular:uptime:up if empty.
UPTIME_KUMA_PORT=3001
UPTIME_KUMA_URL=http://127.0.0.1:3001
UPTIME_KUMA_ADMIN_USERNAME=admin
UPTIME_KUMA_ADMIN_PASSWORD=ChangeMeStrong123
UPTIME_KUMA_CREATE_MONITORS=true
UPTIME_KUMA_DB_NAME=uptime_kuma
UPTIME_KUMA_DB_USERNAME=uptime_kuma
UPTIME_KUMA_DB_PASSWORD=replace-with-64-character-hex

# Umami module. Generated automatically by npm run modular:umami:up if empty.
UMAMI_PORT=3002
UMAMI_URL=http://127.0.0.1:3002
UMAMI_ADMIN_USERNAME=admin
UMAMI_OLD_ADMIN_PASSWORD=umami
UMAMI_ADMIN_PASSWORD=ChangeMeStrong123
UMAMI_WEBSITE_NAME=reduOS-Demo
UMAMI_WEBSITE_DOMAIN=redu-os.local
UMAMI_POSTGRES_DATABASE=umami
UMAMI_POSTGRES_USERNAME=umami
UMAMI_POSTGRES_PASSWORD=replace-with-64-character-hex
UMAMI_APP_SECRET=replace-with-64-character-hex

# GlitchTip module. Generated automatically by npm run modular:glitchtip:up if empty.
GLITCHTIP_PORT=8001
GLITCHTIP_URL=http://127.0.0.1:8001
GLITCHTIP_IMAGE=docker.io/glitchtip/glitchtip:latest
GLITCHTIP_ADMIN_EMAIL=admin@example.com
GLITCHTIP_ADMIN_USERNAME=admin
GLITCHTIP_ADMIN_PASSWORD=ChangeMeStrong123!
GLITCHTIP_ORG_NAME=reduOS
GLITCHTIP_TEAM_NAME=Default-Team
GLITCHTIP_PROJECT_NAME=AI-OS-Demo
GLITCHTIP_SECRET_KEY=replace-with-96-character-hex
GLITCHTIP_POSTGRES_DATABASE=glitchtip
GLITCHTIP_POSTGRES_USERNAME=glitchtip
GLITCHTIP_POSTGRES_PASSWORD=replace-with-64-character-hex
GLITCHTIP_REDIS_PASSWORD=replace-with-64-character-hex
GLITCHTIP_EMAIL_URL=consolemail://
GLITCHTIP_DEFAULT_FROM_EMAIL=no-reply@example.com
GLITCHTIP_ENABLE_USER_REGISTRATION=true
GLITCHTIP_ENABLE_ORGANIZATION_CREATION=true
GLITCHTIP_ENABLE_UPTIME=true
GLITCHTIP_ENABLE_LOGS=true
GLITCHTIP_ENABLE_MCP=false
GLITCHTIP_INSTANCE_NAME=reduOS-GlitchTip

# Listmonk module. Generated automatically by npm run modular:listmonk:up if empty.
LISTMONK_PORT=9000
LISTMONK_URL=http://127.0.0.1:9000
LISTMONK_IMAGE=docker.io/listmonk/listmonk:latest
LISTMONK_ADMIN_USERNAME=admin
LISTMONK_ADMIN_PASSWORD=ChangeMeStrong123
LISTMONK_LIST_NAME=Beta-Users
LISTMONK_LIST_TYPE=public
LISTMONK_LIST_OPTIN=single
LISTMONK_LIST_TAG=waitlist
LISTMONK_POSTGRES_DATABASE=listmonk
LISTMONK_POSTGRES_USERNAME=listmonk
LISTMONK_POSTGRES_PASSWORD=replace-with-64-character-hex

MAX_EVENT_MESSAGE_LENGTH=8000
