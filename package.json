{
  "name": "redu-os",
  "version": "0.1.0",
  "description": "reduOS collector and self-hosted startup operations templates.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "stack:up": "bash scripts/start-local-stack.sh",
    "stack:test": "bash scripts/test-local-stack.sh",
    "stack:down": "bash scripts/stop-local-stack.sh"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@qdrant/js-client-rest": "^1.13.0",
    "@supabase/supabase-js": "^2.47.10",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
